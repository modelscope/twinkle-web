&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;VLM / Multimodal&lt;/td&gt;
&lt;td&gt;✅ (Qwen2.5-VL, Kimi-VL)&lt;/td&gt;
&lt;td&gt;Planned&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;Multi-turn + Tools&lt;/td&gt;
&lt;td&gt;✅&lt;/td&gt;
&lt;td&gt;✅&lt;/td&gt;
&lt;/tr&gt;
&lt;tr&gt;
&lt;td&gt;Multi-tenancy&lt;/td&gt;
&lt;td&gt;-&lt;/td&gt;
